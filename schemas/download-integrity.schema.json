{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "download-integrity.schema.json",
  "title": "DownloadIntegrityRegistry",
  "type": "object",
  "required": [
    "schema_version",
    "downloads"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "downloads": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "version",
          "url",
          "sha256"
        ],
        "additionalProperties": false,
        "properties": {
          "version": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$"
          },
          "workflows": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
