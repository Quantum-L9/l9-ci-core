{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://l9-ci-core/schemas/promotion-decision.schema.json",
  "title": "L9 Control Plane Promotion Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "risk_tier",
    "decision",
    "merge_meaning",
    "policy",
    "required",
    "advisory",
    "shadow",
    "legacy_required",
    "not_selected",
    "missing_results",
    "unexpected_results",
    "control_plane_errors",
    "decision_hash"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "subject_sha", "base_sha", "event_type"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "subject_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "base_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{40}$"
        },
        "event_type": {
          "type": "string",
          "enum": ["pull_request", "merge_group", "push", "workflow_dispatch"]
        }
      }
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "standard", "high", "regulated"]
    },
    "decision": { "type": "string", "enum": ["passed", "blocked"] },
    "merge_meaning": {
      "type": "string",
      "enum": [
        "all_required_gates_passed",
        "required_gate_failed",
        "legacy_required_job_failed",
        "control_plane_failure"
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_registry_digest",
        "risk_policy_digest",
        "rule_modes_digest",
        "gate_plan_digest"
      ],
      "properties": {
        "gate_registry_digest": { "$ref": "#/$defs/digest" },
        "risk_policy_digest": { "$ref": "#/$defs/digest" },
        "rule_modes_digest": { "$ref": "#/$defs/digest" },
        "gate_plan_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "required": { "$ref": "#/$defs/gate_status_list" },
    "advisory": { "$ref": "#/$defs/gate_status_list" },
    "shadow": { "$ref": "#/$defs/gate_status_list" },
    "legacy_required": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["job", "status"],
        "properties": {
          "job": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failure",
              "cancelled",
              "skipped",
              "timed_out",
              "action_required",
              "missing",
              "unknown"
            ]
          }
        }
      }
    },
    "not_selected": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_results": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unexpected_results": {
      "type": "array",
      "items": { "type": "object" }
    },
    "control_plane_errors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "decision_hash": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "gate_status_list": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "state"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "state": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "error",
              "missing",
              "skipped",
              "cancelled",
              "timed_out",
              "action_required",
              "malformed",
              "duplicate_conflict",
              "unknown"
            ]
          }
        }
      }
    }
  }
}
