{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L9 Agent Review Payload",
  "type": "object",
  "required": [
    "repo",
    "commit",
    "branch",
    "pr_class",
    "gate_status",
    "blocking_findings",
    "advisory_findings",
    "failed_checks",
    "skipped_checks",
    "autofix_candidates",
    "manual_review_required",
    "matrix_runs",
    "artifact_provenance",
    "provenance"
  ],
  "properties": {
    "repo": {"type": "string"},
    "commit": {"type": "string"},
    "branch": {"type": "string"},
    "pr_number": {"type": ["string", "null"]},
    "pr_class": {"type": "string"},
    "gate_status": {"enum": ["pass", "fail"]},
    "blocking_findings": {"type": "array", "items": {"type": "object"}},
    "advisory_findings": {"type": "array", "items": {"type": "object"}},
    "failed_checks": {"type": "array", "items": {"type": "object"}},
    "skipped_checks": {"type": "array", "items": {"type": "object"}},
    "infrastructure_failures": {"type": "array", "items": {"type": "object"}},
    "autofix_candidates": {"type": "array", "items": {"type": "object"}},
    "manual_review_required": {"type": "array", "items": {"type": "object"}},
    "matrix_runs": {"type": "array", "items": {"type": "object"}},
    "artifact_provenance": {"type": "object"},
    "provenance": {"type": "object"}
  }
}
