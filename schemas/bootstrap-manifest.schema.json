{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.github.io/l9-ci-core/schemas/bootstrap-manifest.schema.json",
  "title": "L9 Bootstrap Result Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "expected_gates",
    "results",
    "complete",
    "overall_result"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "expected_gates": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "prefixItems": [
        {
          "const": "workflow/action-pins"
        },
        {
          "const": "workflow/download-integrity"
        },
        {
          "const": "dependencies/ci-lock"
        },
        {
          "const": "workflow/contracts"
        }
      ],
      "items": false
    },
    "results": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "complete": {
      "type": "boolean"
    },
    "overall_result": {
      "enum": [
        "passed",
        "failed"
      ]
    }
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "file",
        "result",
        "exit_code"
      ],
      "properties": {
        "gate_id": {
          "enum": [
            "workflow/action-pins",
            "workflow/download-integrity",
            "dependencies/ci-lock",
            "workflow/contracts"
          ]
        },
        "file": {
          "enum": [
            "action-pins.json",
            "download-integrity.json",
            "ci-dependencies.json",
            "workflow-contracts.json"
          ]
        },
        "result": {
          "enum": [
            "passed",
            "failed",
            "error"
          ]
        },
        "exit_code": {
          "enum": [
            0,
            1,
            2
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "result": {
                "const": "passed"
              }
            }
          },
          "then": {
            "properties": {
              "exit_code": {
                "const": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result": {
                "const": "failed"
              }
            }
          },
          "then": {
            "properties": {
              "exit_code": {
                "const": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result": {
                "const": "error"
              }
            }
          },
          "then": {
            "properties": {
              "exit_code": {
                "const": 2
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "complete": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "results": {
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_result": {
            "const": "passed"
          }
        }
      },
      "then": {
        "properties": {
          "complete": {
            "const": true
          },
          "results": {
            "items": {
              "properties": {
                "result": {
                  "const": "passed"
                },
                "exit_code": {
                  "const": 0
                }
              }
            }
          }
        }
      }
    }
  ]
}
