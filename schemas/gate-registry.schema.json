{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.github.io/l9-ci-core/schemas/gate-registry.schema.json",
  "title": "L9 Gate Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "owner",
        "default_mode"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "default_mode": {
          "$ref": "#/$defs/mode"
        }
      }
    },
    "gates": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*/[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/gate"
      }
    }
  },
  "$defs": {
    "mode": {
      "enum": [
        "blocking",
        "advisory",
        "shadow",
        "disabled"
      ]
    },
    "riskTier": {
      "enum": [
        "low",
        "standard",
        "high",
        "regulated"
      ]
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "description",
        "owner_layer",
        "executor",
        "result_adapter",
        "base_result_schema",
        "canonical_result_schema",
        "mode",
        "risk_tiers",
        "selection",
        "timeout_minutes",
        "cost_class",
        "evidence_required",
        "local_cli_compatible",
        "lifecycle"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "owner_layer": {
          "enum": [
            "l9_policy_runtime",
            "l9_assurance",
            "l9_ci_core",
            "l9_platform"
          ]
        },
        "executor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "command_key"
          ],
          "properties": {
            "type": {
              "enum": [
                "local_cli"
              ]
            },
            "command_key": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          }
        },
        "result_adapter": {
          "enum": [
            "bootstrap_v1"
          ]
        },
        "base_result_schema": {
          "type": "string",
          "minLength": 1
        },
        "canonical_result_schema": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "risk_tiers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/riskTier"
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "always_run",
            "paths"
          ],
          "properties": {
            "always_run": {
              "type": "boolean"
            },
            "paths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "timeout_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "cost_class": {
          "enum": [
            "cheap",
            "moderate",
            "expensive"
          ]
        },
        "evidence_required": {
          "type": "boolean"
        },
        "local_cli_compatible": {
          "type": "boolean"
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "warn_since",
            "auto_retire_after_days"
          ],
          "properties": {
            "status": {
              "enum": [
                "active",
                "warn",
                "retired"
              ]
            },
            "warn_since": {
              "oneOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ]
            },
            "auto_retire_after_days": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        }
      }
    }
  }
}
