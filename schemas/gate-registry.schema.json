{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://l9-ci-core/schemas/gate-registry.schema.json",
  "title": "L9 Control Plane Gate Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry", "gates"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "owner", "default_mode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "default_mode": {
          "type": "string",
          "enum": ["blocking", "advisory", "shadow", "disabled"]
        }
      }
    },
    "gates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/gate" }
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "owner_layer",
        "executor",
        "result_adapter",
        "base_result_schema",
        "canonical_result_schema",
        "mode",
        "risk_tiers",
        "selection",
        "timeout_minutes",
        "cost_class",
        "evidence_required",
        "local_cli_compatible",
        "lifecycle"
      ],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "owner_layer": {
          "type": "string",
          "enum": ["l9_policy_runtime", "l9_assurance"]
        },
        "executor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "command_key"],
          "properties": {
            "type": { "type": "string", "enum": ["local_cli"] },
            "command_key": { "type": "string", "minLength": 1 }
          }
        },
        "result_adapter": { "type": "string", "enum": ["bootstrap_v1"] },
        "base_result_schema": { "type": "string", "minLength": 1 },
        "canonical_result_schema": { "type": "string", "minLength": 1 },
        "mode": {
          "type": "string",
          "enum": ["blocking", "advisory", "shadow", "disabled"]
        },
        "risk_tiers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["low", "standard", "high", "regulated"]
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["always_run"],
          "properties": {
            "always_run": { "type": "boolean" },
            "paths": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "timeout_minutes": { "type": "integer", "minimum": 1 },
        "cost_class": {
          "type": "string",
          "enum": ["cheap", "moderate", "expensive"]
        },
        "evidence_required": { "type": "boolean" },
        "local_cli_compatible": { "type": "boolean" },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["active", "warn", "retired"]
            },
            "warn_since": { "type": ["string", "null"] },
            "auto_retire_after_days": {
              "type": ["integer", "null"],
              "minimum": 1
            }
          }
        }
      }
    }
  }
}
