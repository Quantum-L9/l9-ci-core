{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.github.io/l9-ci-core/schemas/changed-files.schema.json",
  "title": "L9 Changed Files",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "files",
    "unknown_diff",
    "reason"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unknown_diff": {
      "type": "boolean"
    },
    "reason": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
