{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://l9-ci-core/schemas/control-plane-migration.schema.json",
  "title": "L9 Control Plane Migration Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "migration_id",
    "subject",
    "before",
    "after",
    "reason",
    "owner",
    "tracking_issue"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "migration_id": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "before": { "type": "string" },
    "after": { "type": "string" },
    "reason": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "tracking_issue": { "type": "string", "minLength": 1 }
  }
}
