{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://l9-ci-core/schemas/risk-tiers.schema.json",
  "title": "L9 Control Plane Risk Tiers",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "default_tier",
    "tiers",
    "classification",
    "fallback",
    "precedence",
    "label_rules",
    "unknown_diff_behavior"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "default_tier": { "$ref": "#/$defs/tier_name" },
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "standard", "high", "regulated"],
      "properties": {
        "low": { "$ref": "#/$defs/tier" },
        "standard": { "$ref": "#/$defs/tier" },
        "high": { "$ref": "#/$defs/tier" },
        "regulated": { "$ref": "#/$defs/tier" }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "regulated": { "$ref": "#/$defs/classification_rule" },
        "high": { "$ref": "#/$defs/classification_rule" },
        "standard": { "$ref": "#/$defs/classification_rule" },
        "low": { "$ref": "#/$defs/classification_rule" }
      }
    },
    "fallback": { "$ref": "#/$defs/tier_name" },
    "precedence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tier_name" }
    },
    "label_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label_may_raise", "label_may_lower"],
      "properties": {
        "label_may_raise": { "type": "boolean" },
        "label_may_lower": { "type": "boolean" }
      }
    },
    "unknown_diff_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_tier", "classification_reason"],
      "properties": {
        "risk_tier": { "$ref": "#/$defs/tier_name" },
        "classification_reason": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "tier_name": {
      "type": "string",
      "enum": ["low", "standard", "high", "regulated"]
    },
    "tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "description"],
      "properties": {
        "rank": { "type": "integer", "minimum": 0 },
        "description": { "type": "string" }
      }
    },
    "classification_rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "any_paths": { "type": "array", "items": { "type": "string" } },
        "all_paths": { "type": "array", "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } },
        "any_labels": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
