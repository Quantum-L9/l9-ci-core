{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.github.io/l9-ci-core/schemas/risk-tiers.schema.json",
  "title": "L9 Risk Tiers",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "default_tier",
    "tiers",
    "classification",
    "fallback",
    "precedence",
    "label_rules",
    "unknown_diff_behavior"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "default_tier": {
      "$ref": "#/$defs/tier"
    },
    "tiers": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/tier"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "description"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 0
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "classification": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/tier"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "any_paths": {
            "$ref": "#/$defs/globList"
          },
          "all_paths": {
            "$ref": "#/$defs/globList"
          },
          "forbidden_paths": {
            "$ref": "#/$defs/globList"
          },
          "any_labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "fallback": {
      "$ref": "#/$defs/tier"
    },
    "precedence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/tier"
      }
    },
    "label_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label_may_raise",
        "label_may_lower"
      ],
      "properties": {
        "label_may_raise": {
          "type": "boolean"
        },
        "label_may_lower": {
          "type": "boolean"
        }
      }
    },
    "unknown_diff_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_tier",
        "classification_reason"
      ],
      "properties": {
        "risk_tier": {
          "$ref": "#/$defs/tier"
        },
        "classification_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "tier": {
      "enum": [
        "low",
        "standard",
        "high",
        "regulated"
      ]
    },
    "globList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
